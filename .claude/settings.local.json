      "Bash(curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh)",
      "Bash(bash)",
      "mcp__Claude_Preview__preview_start",
      "Bash(git init)",
      "Bash(gh auth status)",
      "Bash(brew install gh)",
